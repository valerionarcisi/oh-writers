{
  "name": "@oh-writers/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "migrate": "drizzle-kit migrate",
    "migrate:create": "drizzle-kit generate",
    "migrate:status": "drizzle-kit status",
    "migrate:rollback": "echo 'Use drizzle-kit drop to rollback'",
    "studio": "drizzle-kit studio",
    "seed": "tsx src/seed/index.ts",
    "seed:reset": "tsx src/seed/reset.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.45.1",
    "postgres": "3.4.8"
  },
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@types/node": "22.14.0",
    "drizzle-kit": "0.31.9",
    "tsup": "^8.5.1",
    "tsx": "4.19.2",
    "typescript": "5.9.3"
  }
}
